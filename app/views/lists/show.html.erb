<h1>List</h1>

<% if @bookmarks.any? %>
    <ul>
      <% @bookmarks.each do |bookmark| %>
          <li><%= bookmark.comment %></li>
          <li><%= bookmark.movie.title %></li>
      <% end %>
    </ul>
    <% else %>
    <p>no bookmarks</p>
  <% end %>
<%= link_to "Add a Bookmark", new_list_bookmark_path(@list), class: "btn btn-success my-2 col-2" %>
<%= link_to "Back", lists_path, class: 'btn btn-primary my-2 col-2' %>
