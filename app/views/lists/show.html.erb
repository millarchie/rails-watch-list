<div class="d-flex justify-content-between align-items-center">


</div>


<h1><%= @list.name %></h1>

<% if @bookmarks.any? %>
      <% @bookmarks.each do |bookmark| %>
      <ul>
          <li><h3><%= bookmark.movie.title %></h3></li>
          <p><%= bookmark.comment %></p>
          <%= link_to 'Remove Movie', bookmark_path(bookmark), data: { turbo_method: :delete, turbo_confirm: 'remove this list?'}  %>
      </ul>
      <% end %>
    </ul>
    <% else %>
    <p>no movies</p>
  <% end %>
<%= link_to "Add Movie", new_list_bookmark_path(@list), class: "btn btn-success my-2 col-2" %>
<%= link_to "Back", lists_path, class: 'btn btn-primary my-2 col-2' %>


