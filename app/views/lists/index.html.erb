<div class="banner">
  <div class="container">
    <h1><strong>CineFile</strong></h1>
    <h3 class="text-white">File your favourite movies</h3>
    <%= link_to "Create a File", new_list_path, class: "btn btn-success my-2 col-1.5" %>
  </div>
</div>


<div class="container mt-3">
  <div class="d-flex justify-content-between align-items-center">
    <h1>CineFiles:</h1>
  </div>
  <% if @lists.any? %>
    <div class="cards">
      <% @lists.each do |list| %>
        <div class="card-category" style="background-image: linear-gradient(rgba(0,0,0,0.3), rgba(0,0,0,0.3)), url('https://www.pinterest.com/melodypeavey/2025-movies-shows/')">
          <%= link_to list.name, list_path(list), class: 'text-white text-decoration-none' %>
        </div>
      <% end %>
    </div>
  <% else %>
    <p>No CineFiles Yet</p>
  <% end %>

  <%= link_to "Add a List", new_list_path, class: "btn btn-success my-2 col-2" %>
</div>
