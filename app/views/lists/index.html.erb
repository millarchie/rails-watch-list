<div class="banner">
  <div class="container">
    <h1><strong>Netflist</strong></h1>
    <h1><strong>CineFile</strong></h1>
    <h3 class="text-white">File your favourite movies</h3>
    <a class="btn btn-success mt-3" href="#">Create List</a>
  </div>
</div>





<div class="container mt-3">
  <div class="d-flex justify-content-between align-items-center">
    <h1>Lists</h1>
  </div>




  <% if @lists.any? %>
    <% @lists.each do |list| %>
      <div class="cards">
        <div class="card-category" style="background-image: linear-gradient(rgba(0,0,0,0.3), rgba(0,0,0,0.3)), url(https://raw.githubusercontent.com/lewagon/fullstack-images/master/uikit/lunch.jpg)">
      <%= link_to list.name, list_path(list) %>
        </div>
      </div>
    <% end %>
  <% else %>
    <p>No CineFiles Yet</p>
  <% end %>

  <%= link_to "Add a List", new_list_path, class: "btn btn-success my-2 col-2" %>
</div>
