<div class="container mt-3">
  <div class="d-flex justify-content-between align-items-center">
    <h1>Lists</h1>
  </div>
  <div class="cards">
    <%# <% @lists.each do |list| %>
      <%# <%= render 'lists/card', list: list %>
    <%# <% end %>

  <% if @lists.any? %>
    <ul>
      <% @lists.each do |list| %>
          <li><%= link_to list.name, list_path(list) %></li>
      <% end %>
    </ul>
    <% else %>
    <p>no lists</p>
  <% end %>
  </div>

  <%= link_to "Add a List", new_list_path, class: "btn btn-success my-2 col-2" %>
</div>
